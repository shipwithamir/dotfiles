#!/usr/bin/env bash
# record_controller.sh - Screen recording with mic noise cancellation

RECORD_DIR="$HOME/Videos/recording"
PID_FILE="/tmp/record_game.pid"
STATUS_FILE="/tmp/record_game.status"
META_FILE="/tmp/record_game.meta"

start_recording() {
    if [[ -f "$PID_FILE" ]]; then
        echo "Recording already in progress."
        exit 1
    fi

    DATE=$(date +"%Y-%m-%d")
    TIME=$(date +"%H-%M-%S")
    OUTPUT_DIR="$RECORD_DIR/$DATE"
    mkdir -p "$OUTPUT_DIR"

    VIDEO_FILE="$OUTPUT_DIR/recording_${TIME}.mkv"
    AUDIO_FILE="$OUTPUT_DIR/audio_${TIME}.wav"

    SYSTEM_AUDIO=$(pactl get-default-sink)
    MIC_SOURCE=$(pactl get-default-source)
    SCREEN_SIZE=$(xrandr | awk '/\*/ {print $1; exit}')
    FPS=60

    echo "$VIDEO_FILE|$AUDIO_FILE" > "$META_FILE"

    ffmpeg -y \
        -video_size "$SCREEN_SIZE" \
        -framerate "$FPS" \
        -f x11grab -i :0.0 \
        -f pulse -i "$SYSTEM_AUDIO.monitor" \
        -f pulse -i "$MIC_SOURCE" \
        -filter_complex "
            [2:a]afftdn=nf=-25[mic_nc];
            [1:a][mic_nc]amix=inputs=2:duration=longest[a_mix]
        " \
        -map 0:v \
        -map "[a_mix]" \
        -c:v h264_nvenc -preset p5 -rc vbr -b:v 25M -maxrate 40M -bufsize 80M -pix_fmt yuv420p \
        -c:a aac -b:a 192k \
        -vsync 1 -async 1 \
        "$VIDEO_FILE" \
        > /dev/null 2>&1 &

    echo $! > "$PID_FILE"
    echo "recording" > "$STATUS_FILE"

    echo "Recording started:"
    echo "Video: $VIDEO_FILE"
}

stop_recording() {
    if [[ ! -f "$PID_FILE" ]]; then
        echo "No recording in progress."
        return
    fi

    kill -2 "$(cat "$PID_FILE")"
    wait "$(cat "$PID_FILE")" 2>/dev/null

    rm -f "$PID_FILE"
    echo "stopped" > "$STATUS_FILE"

    IFS="|" read -r VIDEO_FILE AUDIO_FILE < "$META_FILE"
    rm -f "$META_FILE"

    ffmpeg -y \
        -i "$VIDEO_FILE" \
        -vn \
        -acodec pcm_s16le \
        "$AUDIO_FILE" \
        > /dev/null 2>&1

    echo "Recording stopped."
    echo "Extracted audio: $AUDIO_FILE"
}

status() {
    if [[ -f "$PID_FILE" ]]; then
        echo "%{F#FF0000}%{F-} REC"
    else
        echo " idle"
    fi
}

case "$1" in
    start) start_recording ;;
    stop) stop_recording ;;
    status) status ;;
    *) echo "Usage: $0 {start|stop|status}" ;;
esac
